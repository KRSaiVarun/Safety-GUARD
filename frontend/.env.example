# Frontend Environment Variables Template
# Copy this to .env.local for development
# For production, set these in Netlify/Vercel dashboard

# ============================================================
# API ENDPOINTS
# ============================================================
VITE_API_URL=http://localhost:8000
VITE_SOCKET_URL=http://localhost:8000

# ============================================================
# SUPABASE (Auth & Database)
# ============================================================
VITE_SUPABASE_URL=https://nmyoxgcxvokiribbdyzf.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_gJqxl0tUIyoDzt-sw734tw_Dzes2SnQ

# ============================================================
# MAPS & GEOLOCATION
# ============================================================
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
VITE_MAPBOX_ACCESS_TOKEN=your-mapbox-token

# ============================================================
# FEATURES & FLAGS
# ============================================================
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_TRACKING=true
VITE_LOG_LEVEL=info

